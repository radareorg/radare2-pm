R2PM_BEGIN

R2PM_GIT "https://github.com/radareorg/r2garlic"
R2PM_DESC "Garlic DEX/Dalvik decompiler plugin for radare2"

R2PM_INSTALL() {
  git submodule init
  git submodule update
	${MAKE} clean || true
	${MAKE} || R2PM_FAIL "make"
	${MAKE} user-install
}

R2PM_UNINSTALL() {
	${MAKE} user-uninstall
}

R2PM_END
